GRAFANA_API_URL=https://your-stack.grafana.net
GRAFANA_API_KEY=glsa_replace_with_real_key
GRAFANA_WEBHOOK_SECRET=replace-with-strong-shared-secret
ALERT_NAME=Global Spend
POLL_INTERVAL=5m
PROXY_AUTH_HEADER=X-Dappnode
PROXY_AUTH_VALUE=replace-with-shared-proxy-secret
PORT=8080
TARGET_URL=https://faro-collector-prod-eu-west-2.grafana.net/collect/your-collector-id
ALLOY_REMOTE_WRITE_URL=https://prometheus-prod-XX-prod-XX.grafana.net/api/prom/push
ALLOY_REMOTE_WRITE_USER=your-prometheus-username
ALLOY_REMOTE_WRITE_PASS=glc_replace_with_alloy_api_token
